# Atlas Morning Briefing — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# LLM — MiniMax 2.7 (primary)
MINIMAX_API_KEY=

# LLM — OpenRouter (fallback, optional)
OPENROUTER_API_KEY=

# News — Brave Search API
BRAVE_API_KEY=

# Email delivery — Gmail App Password
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Supabase — for newsletter + GitHub trending sources (optional)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
